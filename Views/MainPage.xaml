<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="ClockSystem.WinUI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ClockSystem.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
            <SolidColorBrush x:Key="SecondaryColor" Color="#3498DB"/>
            <SolidColorBrush x:Key="AccentColor" Color="#E74C3C"/>
            <SolidColorBrush x:Key="TextColor" Color="#333333"/>
            <SolidColorBrush x:Key="BorderColor" Color="#E0E0E0"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Margin="20,20,20,10" Padding="20" Background="White" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="母钟时间:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <TextBlock Grid.Column="1" Text="{Binding TimeDisplay, Mode=OneWay}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource SecondaryColor}"/>
                
                <Button Grid.Column="3" Content="同步系统时间" Click="OnSyncTimeClicked" Margin="5,0"/>
                <Button Grid.Column="4" Content="调整时间" Click="OnAdjustTimeClicked" Margin="5,0"/>
                <Button Grid.Column="5" Content="系统设置" Click="OnSettingsClicked" Margin="5,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="20,10,20,10" Padding="20" Background="White" CornerRadius="8">
            <Canvas x:Name="ClockCanvas" Background="#F5F5F5" Margin="20"/>
        </Border>

        <Border Grid.Row="2" Margin="20,10,20,20" Padding="20" Background="White" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="报时系统反馈" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextColor}"/>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogTextBlock" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>

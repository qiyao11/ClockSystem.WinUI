<?xml version="1.0" encoding="UTF-8" ?>
<ContentDialog
    x:Class="ClockSystem.WinUI.Dialogs.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="系统设置"
    PrimaryButtonText="保存"
    SecondaryButtonText="取消"
    DefaultButton="Primary"
    Background="{StaticResource BackgroundBrush}"
    MaxWidth="800"
    MaxHeight="700">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <x:Double x:Key="ContentDialogMaxWidth">800</x:Double>
            <Thickness x:Key="ContentDialogPadding">0</Thickness>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid Width="720" Height="580">
        <TabView IsAddTabButtonVisible="False" 
                 TabWidthMode="Equal"
                 Background="Transparent">
            
            <!-- File Paths Tab -->
            <TabViewItem Header="文件路径">
                <TabViewItem.IconSource>
                    <FontIconSource Glyph="&#xE8B7;"/>
                </TabViewItem.IconSource>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Spacing="20">
                        
                        <!-- Music File Section -->
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8D6;" Foreground="{StaticResource PrimaryBrush}" FontSize="18"/>
                                    <TextBlock Text="音频文件设置" Style="{StaticResource CardTitleStyle}"/>
                                </StackPanel>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="音乐文件" VerticalAlignment="Center" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Grid.Column="1" 
                                             Text="{Binding Config.Path.MusicPath, Mode=TwoWay}" 
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"
                                             PlaceholderText="选择音乐文件路径"/>
                                    <Button Grid.Column="2" 
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BrowseMusicButton_Click"
                                            Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8E5;" FontSize="12"/>
                                            <TextBlock Text="浏览" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="钟声文件" VerticalAlignment="Center" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Grid.Column="1" 
                                             Text="{Binding Config.Path.BellPath, Mode=TwoWay}" 
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"
                                             PlaceholderText="选择钟声文件路径"/>
                                    <Button Grid.Column="2" 
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BrowseBellButton_Click"
                                            Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8E5;" FontSize="12"/>
                                            <TextBlock Text="浏览" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Hour Voice Paths -->
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8E1;" Foreground="{StaticResource SecondaryBrush}" FontSize="18"/>
                                    <TextBlock Text="整点报时语音路径" Style="{StaticResource CardTitleStyle}"/>
                                </StackPanel>
                                <ItemsControl x:Name="HourPathsItemsControl"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Half Hour Voice Paths -->
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8E1;" Foreground="{StaticResource AccentBrush}" FontSize="18"/>
                                    <TextBlock Text="半点报时语音路径" Style="{StaticResource CardTitleStyle}"/>
                                </StackPanel>
                                <ItemsControl x:Name="HalfPathsItemsControl"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- Chime Settings Tab -->
            <TabViewItem Header="报时开关">
                <TabViewItem.IconSource>
                    <FontIconSource Glyph="&#xE7E8;"/>
                </TabViewItem.IconSource>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Spacing="20">
                        
                        <!-- Hour Chime Settings -->
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE823;" Foreground="{StaticResource SecondaryBrush}" FontSize="18"/>
                                    <TextBlock Text="整点报时开关" Style="{StaticResource CardTitleStyle}"/>
                                </StackPanel>
                                <ItemsControl x:Name="HourSwitchesItemsControl"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Half Hour Chime Settings -->
                        <Border Style="{StaticResource CardStyle}" Padding="16">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE823;" Foreground="{StaticResource AccentBrush}" FontSize="18"/>
                                    <TextBlock Text="半点报时开关" Style="{StaticResource CardTitleStyle}"/>
                                </StackPanel>
                                <ItemsControl x:Name="HalfSwitchesItemsControl"/>
                            </StackPanel>
                        </Border>

                        <!-- Quick Actions -->
                        <Border Style="{StaticResource CardStyle}" Padding="16" Background="{StaticResource Gray50Brush}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="批量操作" Style="{StaticResource LabelStyle}" FontSize="13"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" 
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="SelectAllHourButton_Click"
                                            Margin="0,0,6,0"
                                            Padding="8,6">
                                        <TextBlock Text="整点全选" FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="1" 
                                            Style="{StaticResource GhostButtonStyle}"
                                            Click="DeselectAllHourButton_Click"
                                            Margin="6,0,6,0"
                                            Padding="8,6">
                                        <TextBlock Text="整点全不选" FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="2" 
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="SelectAllHalfButton_Click"
                                            Margin="6,0,6,0"
                                            Padding="8,6">
                                        <TextBlock Text="半点全选" FontSize="12"/>
                                    </Button>
                                    <Button Grid.Column="3" 
                                            Style="{StaticResource GhostButtonStyle}"
                                            Click="DeselectAllHalfButton_Click"
                                            Margin="6,0,0,0"
                                            Padding="8,6">
                                        <TextBlock Text="半点全不选" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- Light Settings Tab -->
            <TabViewItem Header="灯光设置">
                <TabViewItem.IconSource>
                    <FontIconSource Glyph="&#xE706;"/>
                </TabViewItem.IconSource>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                    <StackPanel Spacing="20">
                        
                        <Border Style="{StaticResource CardStyle}" Padding="20">
                            <StackPanel Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE706;" Foreground="{StaticResource WarningBrush}" FontSize="24"/>
                                    <TextBlock Text="自动灯光控制" Style="{StaticResource CardTitleStyle}" FontSize="22"/>
                                </StackPanel>
                                
                                <TextBlock Text="设置灯光自动开启和关闭的时间，系统将根据设定时间自动切换时钟显示模式。" 
                                           TextWrapping="Wrap" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           LineHeight="22"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Light On Time -->
                                    <Border Grid.Column="0" 
                                            Background="{StaticResource Gray50Brush}" 
                                            CornerRadius="{StaticResource RadiusMd}"
                                            Padding="16">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE706;" Foreground="{StaticResource SuccessBrush}" FontSize="16"/>
                                                <TextBlock Text="灯光开启时间" Style="{StaticResource LabelStyle}"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding Config.Light.LightOnTime, Mode=TwoWay}" 
                                                     PlaceholderText="HH:MM"
                                                     FontSize="18"
                                                     FontWeight="SemiBold"
                                                     HorizontalAlignment="Center"
                                                     Width="120"/>
                                            <TextBlock Text="格式：HH:MM (24小时制)" 
                                                       FontSize="11" 
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Arrow -->
                                    <FontIcon Grid.Column="1" 
                                              Glyph="&#xE72A;" 
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Foreground="{StaticResource TextMutedBrush}"/>

                                    <!-- Light Off Time -->
                                    <Border Grid.Column="2" 
                                            Background="{StaticResource Gray50Brush}" 
                                            CornerRadius="{StaticResource RadiusMd}"
                                            Padding="16">
                                        <StackPanel Spacing="12">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE708;" Foreground="{StaticResource Gray500Brush}" FontSize="16"/>
                                                <TextBlock Text="灯光关闭时间" Style="{StaticResource LabelStyle}"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding Config.Light.LightOffTime, Mode=TwoWay}" 
                                                     PlaceholderText="HH:MM"
                                                     FontSize="18"
                                                     FontWeight="SemiBold"
                                                     HorizontalAlignment="Center"
                                                     Width="120"/>
                                            <TextBlock Text="格式：HH:MM (24小时制)" 
                                                       FontSize="11" 
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>
        </TabView>
    </Grid>
</ContentDialog>

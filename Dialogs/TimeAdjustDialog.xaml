<?xml version="1.0" encoding="UTF-8" ?>
<ContentDialog
    x:Class="ClockSystem.WinUI.Dialogs.TimeAdjustDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="调整母钟时间"
    PrimaryButtonText="应用"
    SecondaryButtonText="取消"
    PrimaryButtonClick="OnApplyClicked"
    DefaultButton="Primary"
    Background="{StaticResource BackgroundBrush}"
    MaxWidth="600">

    <ContentDialog.Resources>
        <ResourceDictionary>
            <x:Double x:Key="ContentDialogMaxWidth">600</x:Double>
            <Thickness x:Key="ContentDialogPadding">0</Thickness>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid Width="520" Padding="24">
        <StackPanel Spacing="24">
            
            <!-- Header Info -->
            <Border Background="{StaticResource PrimaryLightBrush}" 
                    CornerRadius="{StaticResource RadiusMd}"
                    Padding="16"
                    Opacity="0.1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE70F;" Foreground="{StaticResource PrimaryBrush}" FontSize="20"/>
                    <TextBlock Text="精确设置母钟时间" 
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Date Section -->
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE787;" Foreground="{StaticResource SecondaryBrush}" FontSize="18"/>
                        <TextBlock Text="日期设置" Style="{StaticResource CardTitleStyle}"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Year -->
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="年" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                            <NumberBox x:Name="YearBox" 
                                       Minimum="1900" 
                                       Maximum="2100" 
                                       SpinButtonPlacementMode="Inline"
                                       HorizontalAlignment="Stretch"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                                   FontSize="24" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>

                        <!-- Month -->
                        <StackPanel Grid.Column="2" Spacing="8">
                            <TextBlock Text="月" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                            <NumberBox x:Name="MonthBox" 
                                       Minimum="1" 
                                       Maximum="12" 
                                       SpinButtonPlacementMode="Inline"
                                       HorizontalAlignment="Stretch"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="-" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                                   FontSize="24" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>

                        <!-- Day -->
                        <StackPanel Grid.Column="4" Spacing="8">
                            <TextBlock Text="日" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                            <NumberBox x:Name="DayBox" 
                                       Minimum="1" 
                                       Maximum="31" 
                                       SpinButtonPlacementMode="Inline"
                                       HorizontalAlignment="Stretch"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Time Section -->
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE823;" Foreground="{StaticResource AccentBrush}" FontSize="18"/>
                        <TextBlock Text="时间设置" Style="{StaticResource CardTitleStyle}"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Hour -->
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="时" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                            <NumberBox x:Name="HourBox" 
                                       Minimum="0" 
                                       Maximum="23" 
                                       SpinButtonPlacementMode="Inline"
                                       HorizontalAlignment="Stretch"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="0-23" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                   FontSize="32" Foreground="{StaticResource TextMutedBrush}" FontWeight="Light"/>

                        <!-- Minute -->
                        <StackPanel Grid.Column="2" Spacing="8">
                            <TextBlock Text="分" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                            <NumberBox x:Name="MinuteBox" 
                                       Minimum="0" 
                                       Maximum="59" 
                                       SpinButtonPlacementMode="Inline"
                                       HorizontalAlignment="Stretch"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="0-59" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                   FontSize="32" Foreground="{StaticResource TextMutedBrush}" FontWeight="Light"/>

                        <!-- Second -->
                        <StackPanel Grid.Column="4" Spacing="8">
                            <TextBlock Text="秒" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                            <NumberBox x:Name="SecondBox" 
                                       Minimum="0" 
                                       Maximum="59" 
                                       SpinButtonPlacementMode="Inline"
                                       HorizontalAlignment="Stretch"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="0-59" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <Border Background="{StaticResource Gray50Brush}" 
                    CornerRadius="{StaticResource RadiusMd}"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="快速设置" Style="{StaticResource LabelStyle}" FontSize="13"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Button x:Name="SetCurrentTimeButton"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="SetCurrentTimeButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE895;" FontSize="14"/>
                                <TextBlock Text="设为当前时间" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ResetButton"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="ResetButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="重置" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Preview -->
            <Border Background="{StaticResource Gray800Brush}" 
                    CornerRadius="{StaticResource RadiusMd}"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="预览" FontSize="11" Foreground="{StaticResource Gray400Brush}" FontWeight="Medium"/>
                    <TextBlock x:Name="PreviewTextBlock"
                               Text="2024-01-01 00:00:00"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#10B981"
                               FontFamily="Consolas, Monaco, monospace"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</ContentDialog>

<?xml version="1.0" encoding="UTF-8" ?>
<ContentDialog x:ConnectionId='1'
    x:Class="ClockSystem.WinUI.Dialogs.TimeAdjustDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="调整母钟时间"
    PrimaryButtonText="应用"
    SecondaryButtonText="取消"
                                       
    DefaultButton="Primary">
    
    <ContentDialog.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="TextColor" Color="#333333"/>
        </ResourceDictionary>
    </ContentDialog.Resources>

    <Grid Background="#F5F5F5" Padding="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,10">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="年:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <NumberBox x:ConnectionId='7' x:Name="YearBox" Minimum="1900" Maximum="2100" Width="80"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="月:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <NumberBox x:ConnectionId='6' x:Name="MonthBox" Minimum="1" Maximum="12" Width="60"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="日:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <NumberBox x:ConnectionId='5' x:Name="DayBox" Minimum="1" Maximum="31" Width="60"/>
            </StackPanel>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,10">
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="时:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <NumberBox x:ConnectionId='4' x:Name="HourBox" Minimum="0" Maximum="23" Width="60"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="分:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <NumberBox x:ConnectionId='3' x:Name="MinuteBox" Minimum="0" Maximum="59" Width="60"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="5">
                <TextBlock Text="秒:" VerticalAlignment="Center" Foreground="{StaticResource TextColor}"/>
                <NumberBox x:ConnectionId='2' x:Name="SecondBox" Minimum="0" Maximum="59" Width="60"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ContentDialog>

